# Flask Konfiguration
SECRET_KEY=your-super-secret-key-change-this-to-something-random-and-long
FLASK_ENV=development

# Datenbank (absoluter Pfad zur bestehenden Datenbankdatei)
DATABASE_URL=sqlite:////absolute/path/to/your/mannschaftskasse.db

# VAPID Keys für Push-Benachrichtigungen (optional)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key  
VAPID_EMAIL=your-email@example.com

# Weitere Einstellungen
TIMEZONE=Europe/Berlin

# Vereinsinformationen (Club-Level)
CLUB_NAME=Ihr Verein
CLUB_LOGO=/static/images/vereins-logo.jpg

# Multi-Team-Konfiguration
# Erste Mannschaft
TEAM1_NAME=Erste Mannschaft
TEAM1_SHORT_NAME=Ihr Verein I
TEAM1_PAYPAL_ACCOUNT=paypal1@ihr-verein.de

# Zweite Mannschaft  
TEAM2_NAME=Zweite Mannschaft
TEAM2_SHORT_NAME=Ihr Verein II
TEAM2_PAYPAL_ACCOUNT=paypal2@ihr-verein.de

# FUPA-Integration (gemeinsam für beide Teams)
FUPA_TEAM_SLUG=ihr-verein

# Legacy-Support (wird von TEAM2 übernommen)
TEAM_NAME=Zweite Mannschaft
TEAM_SHORT_NAME=Ihr Verein II
TEAM_LOGO=vereins-logo.jpg
LOGO_URL=/static/images/vereins-logo.jpg

# PWA Einstellungen
THEME_COLOR=#1976d2
BACKGROUND_COLOR=#ffffff

# Google Drive Backup
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here


